        {
          "name": "Daftar (Register)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const body = pm.response.json();",
                "  if (body.data && body.data.token) {",
                "    pm.collectionVariables.set('access_token', body.data.token.akses);",
                "    pm.collectionVariables.set('refresh_token', body.data.token.perbarui);",
                "  }",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/daftar", "host": ["{{base_url}}"], "path": ["api","auth","daftar"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama\": \"Nathan Rahman\",\n  \"email\": \"nathan@example.com\",\n  \"password\": \"Rahasia123\",\n  \"password_confirmation\": \"Rahasia123\"\n}"
            }
          }
        },
        {
          "name": "Masuk (Login)",
