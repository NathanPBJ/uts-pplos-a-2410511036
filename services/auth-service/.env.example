# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=auth_secret
DB_POOL_LIMIT=10

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gunakan string acak minimal 32 karakter (contoh: openssl rand -base64 32)
JWT_ACCESS_SECRET=ganti_dengan_string_acak_minimal_32_karakter
JWT_REFRESH_SECRET=ganti_dengan_string_acak_lain_minimal_32_karakter
JWT_ISSUER=yayasan-satwa-lestari
JWT_AUDIENCE=ys-lestari-clients

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# Dapatkan dari: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# URL ini harus didaftarkan di Google Cloud Console sebagai Authorized redirect URI
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/oauth/google/callback
