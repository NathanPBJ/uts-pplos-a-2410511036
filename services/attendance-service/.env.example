# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development
CORS_ORIGIN=*

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=attendance_db
DB_USER=attendance_user
DB_PASSWORD=attendance_secret
DB_POOL_LIMIT=10

# ─── JWT (shared secret — harus sama dengan auth-service) ────────────────────
JWT_ACCESS_SECRET=ganti_dengan_secret_yang_sama_dengan_auth_service
JWT_ISSUER=yayasan-satwa-lestari
JWT_AUDIENCE=ys-lestari-clients

# ─── Inter-Service Communication ──────────────────────────────────────────────
# URL employee-service (Docker: nama container, lokal: localhost:8080)
EMPLOYEE_SERVICE_URL=http://employee-service:8080
INTERNAL_SERVICE_SECRET=ganti_dengan_secret_internal_yang_sama_dengan_employee_service
