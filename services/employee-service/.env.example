APP_NAME="Employee Service - Yayasan Satwa Lestari"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=employee_db
DB_USERNAME=employee_user
DB_PASSWORD=employee_secret

# ─── Cache & Session ─────────────────────────────────────────────────────────
# API stateless — session tidak dipakai, semua auth lewat JWT via Gateway
CACHE_STORE=file
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ─── JWT (shared secret dengan auth-service) ─────────────────────────────────
# Harus sama persis dengan JWT_ACCESS_SECRET di auth-service
JWT_ACCESS_SECRET=ganti_dengan_secret_yang_sama_dengan_auth_service
JWT_ISSUER=yayasan-satwa-lestari
JWT_AUDIENCE=ys-lestari-clients

# ─── Inter-Service Communication ──────────────────────────────────────────────
# URL internal Docker (gunakan nama container); untuk lokal pakai localhost:PORT
AUTH_SERVICE_URL=http://auth-service:3001
ATTENDANCE_SERVICE_URL=http://attendance-service:3003
INTERNAL_SERVICE_SECRET=ganti_dengan_secret_internal_antar_service
